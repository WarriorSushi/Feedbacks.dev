# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Background processing and abuse/reporting salts
# CRON_SECRET=your-cron-secret
# WEBHOOK_JOB_SECRET=your-webhook-job-secret
# BOARD_REPORT_SALT=your-board-report-salt

# E2E only. `pnpm test:e2e` skips without this; `pnpm test:e2e:required` fails fast.
# E2E_AUTH_BYPASS_SECRET=your-e2e-auth-bypass-secret

# Captcha (optional — only if widget captcha is enabled)
# TURNSTILE_SECRET_KEY=your-turnstile-secret
# HCAPTCHA_SECRET_KEY=your-hcaptcha-secret

# Vote HMAC secret (optional — used for hashing voter IPs)
# VOTE_HMAC_SECRET=your-random-secret-here

# Billing (optional locally, required for paid-plan verification)
# DODO_PAYMENTS_ENVIRONMENT=test
# DODO_PAYMENTS_API_KEY=your-dodo-api-key
# DODO_PAYMENTS_PRO_MONTHLY_PRODUCT_ID=your-dodo-monthly-product-id
# DODO_PAYMENTS_PRO_YEARLY_PRODUCT_ID=your-dodo-yearly-product-id
# DODO_PAYMENTS_WEBHOOK_SECRET=your-dodo-webhook-secret

# Email notifications (optional)
# RESEND_API_KEY=your-resend-api-key
# RESEND_FROM_EMAIL=Feedbacks <notifications@example.com>

# Manual launch verification only — not read by the app.
# Use these to keep real connector test credentials out of notes and shell history.
# REAL_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# REAL_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# REAL_GENERIC_WEBHOOK_URL=https://example.com/webhooks/feedback
# REAL_GITHUB_ISSUES_REPO=owner/repo
# REAL_GITHUB_TOKEN=github_pat_...
